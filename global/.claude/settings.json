{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },

  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(tmux *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Task"
    ],
    "deny": [
      "Read(~/.claude.json)",
      "Read(~/.ssh/*)"
    ],
    "defaultMode": "bypassPermissions"
  },

  "alwaysThinkingEnabled": true,
  "teammateMode": "tmux",
  "cleanupPeriodDays": 30
}
