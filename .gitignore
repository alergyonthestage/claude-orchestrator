# Legacy central layout — REMOVED by the decentralized cutover, but kept ignored
# as a safety net (a migrating user's old vault may still linger here as a
# fallback; never commit it). New config lives in <repo>/.cco/ + ~/.cco/.
/user-config/
/global/
/projects/

# Secrets
.env
.env.*
secrets.env
# Decentralized committed project config: <repo>/.cco/ is tracked, but its
# secrets.env (real secret values) is always gitignored — only the
# secrets.env.example skeleton is committed.
**/.cco/secrets.env
# Legacy secret paths (pre-cutover)
user-config/global/secrets.env
global/secrets.env
# Allow template secrets.env (tracked tool code — the scaffold skeleton)
!templates/project/base/secrets.env

# Claude Code local settings (generated per-session)
.claude/settings.local.json

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
