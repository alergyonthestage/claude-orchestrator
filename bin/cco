#!/usr/bin/env bash
set -euo pipefail

# Catch silent crashes (set -e/set -u violations, syntax errors).
# Expected errors (die, return 1) are caught by the dispatcher and exit
# cleanly — only truly unexpected exits trigger this message.
_cco_completed=false
trap '_ec=$?; if [[ "$_cco_completed" != "true" ]]; then echo "✗ cco exited unexpectedly (exit $_ec). Run with CCO_DEBUG=1 for details." >&2; [[ "${CCO_DEBUG:-}" == "1" ]] && echo "[cco] last command: ${BASH_COMMAND}" >&2; fi' EXIT

# ── Constants ────────────────────────────────────────────────────────
# Resolve this script's real path, following symlinks (L5): a PATH symlink
# like /usr/local/bin/cco -> .../bin/cco must still locate the tool root.
# Uses a readlink loop rather than `readlink -f`, which is absent on macOS.
_cco_src="${BASH_SOURCE[0]}"
while [[ -h "$_cco_src" ]]; do
    _cco_dir="$(cd -P "$(dirname "$_cco_src")" >/dev/null 2>&1 && pwd)"
    _cco_src="$(readlink "$_cco_src")"
    [[ "$_cco_src" == /* ]] || _cco_src="$_cco_dir/$_cco_src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_cco_src")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
unset _cco_src _cco_dir
# Framework asset root — the shipped, read-only trees: defaults/, templates/,
# migrations/, and changelog.yml. Overridable via CCO_FRAMEWORK_ROOT so tests can
# point cco at a throwaway copy and mutate it hermetically (no in-place writes to
# the tracked tree; concurrency/abort-safe). Defaults to the repo root. REPO_ROOT
# alone still locates lib/, bin/, docs/, and internal/ (never relocated).
FRAMEWORK_ROOT="${CCO_FRAMEWORK_ROOT:-$REPO_ROOT}"
DEFAULTS_DIR="$FRAMEWORK_ROOT/defaults"
NATIVE_TEMPLATES_DIR="$FRAMEWORK_ROOT/templates"
IMAGE_NAME="claude-orchestrator:latest"
LIB_DIR="$REPO_ROOT/lib"

# ── User config directory resolution ─────────────────────────────────
# CCO_USER_CONFIG_DIR is the LEGACY-vault pointer ONLY: the pre-decentralized
# user-config store that `cco init --migrate` reads from (and offers to remove).
# It is read-only/migration-only and may be absent (an npm install never had a
# clone-era vault). It is NO LONGER the runtime root for the internal
# tutorial/config-editor sessions — that moved to machine-local STATE via
# _cco_internal_runtime_dir() so nothing writes inside a possibly read-only
# framework tree (ADR-0037 D5). It is also NOT the home of the personal flat
# stores — packs/templates live in the CONFIG bucket (~/.cco) and llms
# content+cache-state in CACHE (F1; design §2.2/§2.3, ADR-0016 D7/D8). Projects
# are decentralized in each repo's <repo>/.cco/ and resolve through the STATE
# index (P5; no $PROJECTS_DIR).
USER_CONFIG_DIR="${CCO_USER_CONFIG_DIR:-$REPO_ROOT/user-config}"

# Global (user) Claude config home is ~/.cco/.claude (ADR-0028, flat — no
# `global/` wrapper). Resolved on demand via _cco_global_claude_dir() (paths.sh);
# there is no eager GLOBAL_DIR / CCO_GLOBAL_DIR variable. PACKS_DIR/TEMPLATES_DIR/
# LLMS_DIR are assigned AFTER the module load below, since their decentralized
# homes derive from the bucket resolvers in paths.sh (_cco_config_dir / _cco_cache_dir).

# ── Load modules ─────────────────────────────────────────────────────
source "$LIB_DIR/colors.sh"
source "$LIB_DIR/utils.sh"
source "$LIB_DIR/paths.sh"
source "$LIB_DIR/access-scope.sh"
source "$LIB_DIR/migrate.sh"
source "$LIB_DIR/index.sh"
source "$LIB_DIR/sync-meta.sh"
source "$LIB_DIR/reminders.sh"
source "$LIB_DIR/auth.sh"
source "$LIB_DIR/yaml.sh"
source "$LIB_DIR/secrets.sh"
source "$LIB_DIR/session-context.sh"
source "$LIB_DIR/packs.sh"
source "$LIB_DIR/llms.sh"
source "$LIB_DIR/local-paths.sh"
source "$LIB_DIR/update-hash-io.sh"
source "$LIB_DIR/update-merge.sh"
source "$LIB_DIR/update-meta.sh"
source "$LIB_DIR/update-discovery.sh"
source "$LIB_DIR/update-sync.sh"
source "$LIB_DIR/update-changelog.sh"
source "$LIB_DIR/update-remote.sh"
source "$LIB_DIR/update.sh"
source "$LIB_DIR/cmd-build.sh"
source "$LIB_DIR/cmd-init.sh"
source "$LIB_DIR/cmd-start.sh"
source "$LIB_DIR/cmd-new.sh"
source "$LIB_DIR/cmd-resolve.sh"
source "$LIB_DIR/cmd-sync.sh"
source "$LIB_DIR/tags.sh"
source "$LIB_DIR/cmd-config.sh"
source "$LIB_DIR/cmd-stop.sh"
source "$LIB_DIR/cmd-chrome.sh"
source "$LIB_DIR/cmd-project-query.sh"
source "$LIB_DIR/cmd-project-add.sh"
source "$LIB_DIR/cmd-project-validate.sh"
source "$LIB_DIR/cmd-project-coords.sh"
source "$LIB_DIR/cmd-project-export-import.sh"
source "$LIB_DIR/cmd-project-rename.sh"
source "$LIB_DIR/cmd-pack.sh"
source "$LIB_DIR/cmd-llms.sh"
source "$LIB_DIR/cmd-template.sh"
source "$LIB_DIR/cmd-update.sh"
source "$LIB_DIR/cmd-clean.sh"
source "$LIB_DIR/cmd-remote.sh"
source "$LIB_DIR/remote.sh"
source "$LIB_DIR/cmd-forget.sh"
source "$LIB_DIR/cmd-join.sh"
source "$LIB_DIR/cmd-docs.sh"
source "$LIB_DIR/cmd-whoami.sh"

# R6 — explicit `none` contract (must precede the store-dir resolvers below, whose
# in-container path resolution would otherwise emit a spurious ADR-0007 warning).
# At cco_access=none, `cco start` injects the session context (CCO_SESSION_CONTEXT)
# but NOT the operator env, so the baked `cco` binary is on PATH yet not in
# operator mode. Without this guard it falls through to the HOST dispatcher —
# emitting a wrong host-resolve refusal, leaking `cco list` output, and printing
# raw host help. Refuse EVERY invocation (including --version/--help/docs) cleanly,
# exit 2 (policy). The CCO_SESSION_CONTEXT marker identifies a genuine session
# (present at every level, unset by the test harness); the operator check excludes
# read+/edit sessions (handled by the shim). Robust to absolute-path invocation.
if _cco_in_container && [[ -n "${CCO_SESSION_CONTEXT:-}" ]] && ! _cco_container_operator; then
    refuse "cco is not available at this access level (cco_access=none). Start a session with --cco-access read-project (the default) or higher to use cco, or run cco on your host."
fi

# Personal flat stores in their decentralized homes (F1; design §2.2/§2.3,
# ADR-0016 D7/D8): packs/templates → CONFIG (~/.cco), llms content+cache-state →
# CACHE. CONFIG has no XDG override, so the plain $HOME form matches
# _cco_config_dir without an eager resolver call at startup;
# CACHE is XDG-overridable, so llms derives from the resolver. A CCO_* override
# always wins (tests/dev seams). Grouped here (post-paths.sh) for the resolver.
PACKS_DIR="${CCO_PACKS_DIR:-$HOME/.cco/packs}"
TEMPLATES_DIR="${CCO_TEMPLATES_DIR:-$HOME/.cco/templates}"
LLMS_DIR="${CCO_LLMS_DIR:-$(_cco_llms_dir)}"

usage() {
    # D7: `--host` (in-container) shows the FULL list with host-only verbs flagged;
    # the default is the filtered list. Ignored on the host.
    local _want_host=false _a
    for _a in "$@"; do [[ "$_a" == "--host" ]] && _want_host=true; done
    local _body
    _body=$(cat <<'EOF'
Usage: cco <command> [options]

Project lifecycle:
  init                   Scaffold this repo's .cco/ project config (+ global on first run)
  join <project>         Add the current repo to <project> as a member (--sync to receive config)
  forget <project>       Deregister a project on this machine (--purge to also delete owned .cco/)

Setup & maintenance:
  build                  Build/rebuild the Docker image
  update                 Run migrations + discover updates (--sync, --diff, --news)
  docs [<topic>]         Browse the bundled user documentation offline
  clean                  Clean up .bak, .tmp/, docker-compose.yml

Sessions:
  start [project]        Start a session (cwd-first, or a named project)
  new                    Start a temporary session with specific repos
  stop [project]         Stop running session(s)

Local paths & sync:
  resolve [project]      Resolve repos/mounts into the machine-local index
  sync [repo] [--from r] Copy .cco config between a project's repos (copy, no merge)

Discovery:
  list [<kind>] [--tag]  Unified index of your resources (all, or one <kind>)
  tag <add|remove>       Tag a pack/project/template (per-user, never team-shared)

Resources:
  project <cmd>          Manage projects (add, validate, coords, rename, show, export, import)
  pack <cmd>             Manage knowledge packs (create, install, update, ...)
  llms <cmd>             Manage llms.txt framework docs (install, update, ...)
  template <cmd>         Manage project/pack templates (create, show, install, ...)

Tools & Sharing:
  chrome <cmd>           Manage Chrome debug session on host
  config <save|push|pull> Version + sync your personal ~/.cco store
  remote <cmd>           Manage sharing-repo remotes

Run 'cco help' for this message, or 'cco <command> --help' for command-specific help.
Use 'cco --version' to print the version, 'cco --help' for this message.
EOF
)
    # Host mode: print the usage verbatim. Container-operator mode (ADR-0042/D7):
    # the header caveats are RECOMPUTED from the resolved level (S6-04 — no more
    # reciting gates that don't apply at edit-all), and the command list is FILTERED
    # to what this session can run by default; `cco --help --host` shows the full
    # list with host-only verbs flagged.
    if _cco_container_operator; then
        local _level="${CCO_CCO_ACCESS:-read-project}"
        [[ "$_level" == "read" ]] && _level="read-all"
        # Derive from the resolved (G,Pc,Po) triple (INV-E). _rs/_ws stay ordinal for
        # the one-line summary; the caveats are recomputed PER AXIS so edit-global's
        # dual-write (Pc=rw AND G=rw) is described correctly (the old ordinal caveat
        # wrongly told edit-global it could not edit the project).
        local _hg _hpc _hpo; read -r _hg _hpc _hpo <<< "$(_env_triple)"
        local _rs _ws
        _rs=$(_env_read_scope)
        _ws=$(_env_write_scope)
        local _cav=""
        [[ "$_hpc" != "rw" ]] && _cav="project-config edits need Pc=rw (edit-project/edit-global/edit-all)"
        [[ "$_hg"  != "rw" ]] && _cav="${_cav:+$_cav; }global-store writes (pack/template/llms/tag/remote/config save) need G=rw (edit-global/edit-all)"
        [[ "$_hpo" != "rw" ]] && _cav="${_cav:+$_cav; }cross-project writes need Po=rw (edit-all)"
        [[ "$(_cco_axis_rank "$_hg")" -lt 1 ]] && _cav="${_cav:+$_cav; }template/remote listing needs G≥ro (read-global+)"
        printf 'Container session (cco_access=%s) — wrapped cco (read %s, write %s).\n' "$_level" "$_rs" "$_ws"
        [[ -n "$_cav" ]] && printf 'At this scope: %s.\n' "$_cav"
        # Fully host-only top-level verbs (mirror the shim blocklist) + `tag` when
        # this session cannot write (no edit level) — those are above-scope here.
        local _hostonly='init|join|forget|build|start|new|stop|resolve|sync|update|clean|chrome'
        local _filter="$_hostonly"
        [[ "$_ws" == "none" ]] && _filter="${_filter}|tag"   # tag is write-only → above a read level
        if $_want_host; then
            # Full list, host-only verbs flagged (host help escape hatch).
            printf '\n'
            printf '%s\n' "$_body" \
                | sed -E "/^  ($_hostonly)([[:space:]]|\$)/ s/\$/   (host only — run on your host)/"
        else
            # D7 default: omit host-only (and above-scope) verbs; note how many hidden.
            local _n; _n=$(printf '%s\n' "$_body" | grep -cE "^  ($_filter)([[:space:]]|\$)")
            printf '\n'
            printf '%s\n' "$_body" | sed -E "/^  ($_filter)([[:space:]]|\$)/d"
            printf "\n%d host-only/above-scope verbs hidden — run 'cco --help --host' to list them.\n" "$_n"
        fi
        return 0
    fi
    printf '%s\n' "$_body"
}

# Print the cco version. Source of truth = package.json `version` at the package
# root (ADR-0037 D7) — no hardcoded string to drift. jq is already required.
_cco_print_version() {
    local pkg="$REPO_ROOT/package.json" v=""
    [[ -f "$pkg" ]] && command -v jq >/dev/null 2>&1 && v="$(jq -r '.version // empty' "$pkg" 2>/dev/null)"
    if [[ -n "$v" ]]; then
        printf 'cco %s\n' "$v"
    else
        printf 'cco (version unknown — package.json not found under %s)\n' "$REPO_ROOT"
    fi
}

# ── Container-operator whitelist/blocklist shim (ADR-0036 D4) ─────────
# When cco runs in-container behind the wrapped-cco shim (container-operator
# mode — see _cco_container_operator in paths.sh), only a safe, path-free subset
# of verbs is permitted. Everything else dies early with a "run it on the host"
# hint, so a session agent can never spawn containers, resolve/rewrite host
# paths, or touch network/credential state. Classification is DEFAULT-DENY: a
# verb (or subcommand) reaches the real dispatcher only if it is explicitly
# whitelisted here. Read verbs are allowed from read-project up, but read scope
# gates the personal-global MANAGEMENT namespaces (`template …`, `remote list`):
# they need read-global or higher (ADR-0042). Unified discovery (`cco list …`)
# stays available at any read level — it is the on-demand model's cornerstone.
# Write verbs that mutate CONFIG or the internal XDG registries through the shared
# cco functions are allowed only under an edit level (CCO_CCO_ACCESS ∈
# edit-project|edit-global|edit-all).
_cco_operator_shim() {
    local cmd="$1"; shift
    local sub="${1:-}"
    local level="${CCO_CCO_ACCESS:-read-project}"
    # Back-compat: a container launched before ADR-0042 may carry the bare `read`
    # value — it meant "read everything", so treat it as read-all here too.
    [[ "$level" == "read" ]] && level="read-all"
    local host_hint="Run it on the host instead (this is a container session; ADR-0036 D4)."
    # The session's resolved (G,Pc,Po) triple — the SINGLE source every gate keys
    # off (access-scope.sh, INV-E; ADR-0046 §7). Authoritative from CCO_ACCESS_TRIPLE
    # (set host-side by `cco start`), with a preset fallback derived from `level`
    # (CCO_CCO_ACCESS) for a back-compat launch. read_scope stays as the ordinal
    # display value; write gating is per-axis (edit-global now grants Pc=rw).
    local _tg _tpc _tpo; read -r _tg _tpc _tpo <<< "$(_env_triple)"
    local read_scope; read_scope=$(_env_read_scope)

    # _op_write <verb-label> <target-tree: project|global|all> — a write verb reaches
    # the dispatcher only if the session triple grants the TARGET TREE's axis (§7:
    # project→Pc=rw, global→G=rw, all→Po=rw); otherwise refuse (exit 2, D8) before
    # the ro FS. edit-global's redefined (rw,rw,none) now satisfies BOTH project
    # (Pc=rw) and global (G=rw), whatever project is named.
    _op_write() {
        _cco_triple_write_satisfies "$_tg" "$_tpc" "$_tpo" "$2" && return 0
        case "$2" in
            project) refuse "'cco $1' edits project config — needs Pc=rw (an edit-project/edit-global/edit-all session; current cco_access=$level)." ;;
            global)  refuse "'cco $1' writes the personal store/registry — needs G=rw (an edit-global/edit-all session; current cco_access=$level)." ;;
            all)     refuse "'cco $1' writes across projects — needs Po=rw (an edit-all session; current cco_access=$level)." ;;
            *)       refuse "'cco $1' needs a wider edit access level (current cco_access=$level)." ;;
        esac
    }
    # _op_read_scope <required-read-scope: global|all> <verb-label> — a read verb
    # whose minimum read tier exceeds the session's is refused (exit 2). The
    # global-class tier (template/remote) is keyed off the G AXIS (needs G≥ro), so a
    # case-6 `(none,rw,rw)` session (read ordinal 'all' yet G=none) is still refused.
    _op_read_scope() {
        case "$1" in
            all)    [[ "$read_scope" == "all" ]] && return 0 ;;
            global) [[ "$(_cco_axis_rank "$_tg")" -ge 1 ]] && return 0 ;;
            *)      return 0 ;;
        esac
        refuse "'cco $2' needs read-$1 scope or higher in this session (current cco_access=$level). Widen it on the host with --cco-access read-$1."
    }
    # R9 refusal taxonomy (D8 exit codes): host-only + removed-alias are POLICY
    # refusals (exit 2), unknown verbs/subcommands are ERRORS (exit 1). Kept as
    # named helpers so each arm reads as its case, and the message never leaves a
    # trailing space (the '${x:+ $x}' idiom).
    _op_hostonly()    { refuse "'cco $1' is host-only. $host_hint"; }                          # exit 2
    _op_removed_list() { refuse "'cco $1 list' was removed — use 'cco list $1' (ADR-0029)."; }  # exit 2
    _op_unknown_sub() { die "Unknown '$1' command: '$2'. Run 'cco $1 --help'."; }              # exit 1

    # D7: per-command `--help`/`-h` is INFORMATIONAL and always available — never
    # refused, even for host-only verbs (the dispatcher prints usage). This is what
    # makes `cco start --help` show usage rather than refuse (S3-6/S7-04/F5).
    case "$sub" in -h|--help) return 0 ;; esac

    case "$cmd" in
        # Host-only: container-spawning, path-resolving / non-transactional
        # lifecycle, and host-side tooling → policy refusal (exit 2).
        start|stop|build|new|resolve|sync|init|join|forget|update|clean|chrome|path)
            if [[ "$cmd" == "path" && "$sub" == "list" ]]; then return 0; fi   # read-only listing OK
            _op_hostonly "$cmd${sub:+ $sub}" ;;
        # Read-only, always available under operator mode. `whoami` is the F4
        # session-introspection verb — read-safe, no host paths, resolvable rather
        # than default-denied (it must be in the known-verb set for that).
        list|docs|help|whoami|--version|-v) return 0 ;;
        tag)
            case "$sub" in
                "") return 0 ;;   # bare namespace → dispatcher prints sub-usage
                add|remove|rm) _op_write "tag $sub" global ;;   # DATA registry (C1: global regardless of named project)
                *) _op_unknown_sub tag "$sub" ;;
            esac ;;
        config)
            case "$sub" in
                "") return 0 ;;
                # host-only: `config validate` sweeps machine-local internal state
                # (the STATE index of logical→HOST paths, per-id STATE/CACHE dirs,
                # the STATE token store) to detect orphans. In a container only the
                # index FILE is mounted (ro, carrying host paths that never resolve
                # in-container) while the STATE dirs/token store are absent, so the
                # sweep would flag every entry as an orphan AND print host paths
                # (INV-4 leak). It is coherent only host-side (CLI-surface review,
                # 2026-07-02).
                validate) refuse "'cco config validate' is host-only — it sanitizes machine-local index/state that is not coherent inside a container. $host_hint" ;;
                save) _op_write "config save" global ;;   # ~/.cco personal store
                push|pull) refuse "'cco config $sub' is host-only (network + credentials). $host_hint" ;;
                *) _op_unknown_sub config "$sub" ;;
            esac ;;
        remote)
            case "$sub" in
                "") return 0 ;;
                list) _op_read_scope global "remote list"; return 0 ;;   # personal-global registry
                add|remove) _op_write "remote $sub" global ;;            # DATA registry
                set-token|remove-token) refuse "'cco remote $sub' is host-only (secrets stay off the container). $host_hint" ;;
                *) _op_unknown_sub remote "$sub" ;;
            esac ;;
        pack|template|llms)
            case "$sub" in
                "") return 0 ;;   # bare namespace → dispatcher prints sub-usage
                list) _op_removed_list "$cmd" ;;   # ADR-0029 redirect (exit 2) — was: pack list executed, project list default-denied
                show|validate)
                    # Templates are a personal-global resource (scaffold new
                    # projects), not a project resource → read-global+ (ADR-0042).
                    [[ "$cmd" == "template" ]] && _op_read_scope global "template $sub"
                    return 0 ;;
                create|update|remove|install|import|internalize|rename) _op_write "$cmd $sub" global ;;
                publish|export) _op_hostonly "$cmd $sub" ;;
                *) _op_unknown_sub "$cmd" "$sub" ;;
            esac ;;
        project)
            case "$sub" in
                "") return 0 ;;
                show|validate|coords) return 0 ;;
                list) _op_removed_list project ;;   # ADR-0029 redirect (exit 2)
                rename) refuse "'cco project rename' is host-only (re-keys machine-local state). $host_hint" ;;
                export|import|add) _op_hostonly "project $sub" ;;
                *) _op_unknown_sub project "$sub" ;;
            esac ;;
        share|manifest) refuse "'cco $cmd' has been removed." ;;
        # Unknown TOP-LEVEL verb → an ERROR (exit 1), NOT a host-only refusal. This
        # removes the "run 'cco whoami' on the host" misfire (NEW-1): an unrecognized
        # verb is a typo, not something that lives on the host.
        *) die "Unknown cco command: '$cmd'. Run 'cco help' for the available commands." ;;
    esac
}

# Verbs whose execution reads or writes the INTERNAL STORE (STATE index, DATA
# registries, CACHE internals) — the trees confined behind the cco-svc privilege
# boundary (ADR-0047). In a container-operator session these are unreachable as the
# `claude` user (EACCES on the 0700 root); they are re-executed elevated via the
# setuid helper (see Main), where the (G,Pc,Po) gate + output-scoping run keyed off
# the trusted :ro session descriptor. Config-content-only verbs (e.g. `config save`,
# which writes the claude-owned ~/.cco) are deliberately NOT listed — they run as
# claude so cco-svc never writes a claude-owned tree. Default-deny: unlisted ⇒ not
# elevated (runs as claude; a store touch would EACCES, surfacing the miss loudly
# rather than silently leaking). Usage: _cco_verb_touches_store <cmd> <sub>
_cco_verb_touches_store() {
    local c="$1" s="${2:-}"
    case "$c" in
        list)    return 0 ;;                                          # index + DATA tags + source
        path)    [[ "$s" == "list" ]] && return 0 ;;                  # index (host paths)
        tag)     case "$s" in add|remove|rm) return 0 ;; esac ;;      # DATA tags.yml write
        remote)  [[ "$s" == "list" ]] && return 0 ;;                  # DATA remotes registry
        project) case "$s" in show|validate|coords) return 0 ;; esac ;;  # index membership
        pack|template|llms) case "$s" in show|validate) return 0 ;; esac ;;  # DATA source provenance
    esac
    return 1
}

# ── Main ─────────────────────────────────────────────────────────────

cmd="${1:-}"
# No command → print usage and exit cleanly. Mark completion so the EXIT trap
# does not misreport this normal exit-0 path as an unexpected crash.
[[ -z "$cmd" ]] && { usage; _cco_completed=true; exit 0; }
shift

# Top-level --version/-v and --help/-h (FI-11): handled before the dispatch (and
# before the J0 bootstrap below) so they work with no other args and have no side
# effects — `cco --version` is a pure query. Per-subcommand --help is unaffected.
case "$cmd" in
    --version|-v) _cco_print_version; _cco_completed=true; exit 0 ;;
    --help|-h)    usage "$@";         _cco_completed=true; exit 0 ;;
esac

# Container-operator mode (ADR-0036 D4): cco runs in-container behind the
# whitelist shim. Classify the verb FIRST — host-only ones die with a hint —
# and SKIP the host first-run bootstrap (the buckets are bind-mounted by
# `cco start`, never created here). Otherwise fall through to the normal
# host bootstrap + dispatch.
_cco_store_helper=/usr/local/bin/cco-svc-helper
if [[ "$cmd" == "__store" ]] && _cco_container_operator; then
    # Elevated re-entry (ADR-0047): the setuid helper re-execs `cco __store <verb> …`
    # as cco-svc to cross the internal-store privilege boundary. Peel the marker verb
    # and fall through to the gate + dispatch below — now running as cco-svc with the
    # store reachable and the TRUSTED (G,Pc,Po) triple the helper injected from the
    # :ro session descriptor (never the agent-mutable env). This re-run of the shim is
    # the AUTHORITATIVE gate (the outer, claude-side gate keys off forgeable env, so it
    # is only an early UX check). The single physical enforcement point.
    cmd="${1:-}"; shift 2>/dev/null || true
    [[ -z "$cmd" ]] && die "Malformed elevated re-entry: '__store' needs a verb."
    _cco_operator_shim "$cmd" "$@"
elif _cco_container_operator; then
    _cco_operator_shim "$cmd" "$@"
    # Trampoline store-touching verbs across the boundary so they run elevated. Guard
    # on the helper being present + not already elevated: an image built before Phase
    # II (no helper; the store was mounted the old claude-readable way) and the test
    # env both fall back to running the verb here, unchanged. The helper injects the
    # trusted scope and execs `cco __store …`; exec replaces this process, so the
    # elevated cco's stdio IS the terminal (no capture/relay needed).
    if [[ "${CCO_STORE_ELEVATED:-}" != "1" && -x "$_cco_store_helper" ]] \
        && _cco_verb_touches_store "$cmd" "${1:-}"; then
        exec "$_cco_store_helper" "$cmd" "$@"
    fi
else
    # J0 first-run bootstrap of the four decentralized-config roots + the legacy-
    # vault safety-net backup, before any command runs (ADR-0017 D3 / ADR-0006 /
    # ADR-0025). Host-side only (H4); idempotent (M6/F43). The BACKUP step is non-fatal
    # (|| true); root bootstrap CAN abort under set -e if the dirs can't be created —
    # that is intentional, cco cannot run without its roots (A5).
    _cco_first_run "$cmd"
fi

# Dispatch command — capture return code so expected errors (die, return 1)
# don't trigger the "exited unexpectedly" trap. Only true crashes (set -e/set -u
# violations before reaching the dispatcher) show the unexpected exit message.
_cco_rc=0
case "$cmd" in
    init)    cmd_init "$@"  || _cco_rc=$? ;;
    join)    cmd_join "$@"  || _cco_rc=$? ;;
    forget)  cmd_forget "$@" || _cco_rc=$? ;;
    build)   cmd_build "$@" || _cco_rc=$? ;;
    start)   cmd_start "$@" || _cco_rc=$? ;;
    new)     cmd_new "$@"   || _cco_rc=$? ;;
    resolve) cmd_resolve "$@" || _cco_rc=$? ;;
    path)    cmd_path "$@"     || _cco_rc=$? ;;
    sync)    cmd_sync "$@"     || _cco_rc=$? ;;
    tag)     cmd_tag "$@"      || _cco_rc=$? ;;
    list)    cmd_list "$@"     || _cco_rc=$? ;;
    config)  cmd_config "$@"   || _cco_rc=$? ;;
    project)
        subcmd="${1:-}"
        if [[ -z "$subcmd" || "$subcmd" == "--help" || "$subcmd" == "-h" ]]; then
            cat <<'EOF'
Usage: cco project <command> [options]

Commands:
  export [name]          Export a project's config as a .tar.gz snapshot
  import <archive>       Import a project from a .tar.gz snapshot
  add <res> <name>       Embed a repo|mount|llms|pack coordinate (cwd-first)
  validate [name]        Check share-readiness (coordinates, no path leaks)
  coords                 Show/reconcile coordinate consistency across units
  rename [<old>] <new>   Rename a project, re-keying its identity across stores
  show <name>            Show project details (repos, packs, config)

List projects with 'cco list project' (or 'cco list' for all resources).
A project has no install/publish/remove — it rides its code-repo remote;
deregister cco's machine-local bookkeeping with 'cco forget' (ADR-0018 D2).

Run 'cco project <command> --help' for command-specific options.
EOF
            exit 0
        fi
        shift
        case "$subcmd" in
            publish|install|update|internalize)
                die "'cco project $subcmd' was removed — a project rides its code-repo remote, not a sharing repo (ADR-0018 D2). Use 'cco project export|import' to move a project's config as a tar, or 'cco init --template <name>' to start from a template." ;;
            resolve)
                die "'cco project resolve' was removed — use the top-level 'cco resolve <name>' (decentralized, cwd-first; ADR-0017 D2)." ;;
            add-pack|remove-pack)
                die "'cco project $subcmd' was removed — use 'cco project add pack <name>' to embed a pack coordinate (ADR-0023 D3 / AD12 no-alias)." ;;
            delete)
                die "'cco project delete' was removed — a project's config lives in its repo at <repo>/.cco/; remove it with normal git/filesystem ops. To deregister cco's machine-local bookkeeping for a project, use 'cco forget <project>' (the repo is untouched; ADR-0021)." ;;
            validate)    cmd_project_validate "$@" ;;
            coords)      cmd_project_coords "$@" ;;
            rename)      cmd_project_rename "$@" ;;
            export)      cmd_project_export "$@" ;;
            import)      cmd_project_import "$@" ;;
            add)         cmd_project_add "$@" ;;
            list)        die "'cco project list' was removed — use 'cco list project' (ADR-0029)." ;;
            show)        cmd_project_show "$@" ;;
            *)        die "Unknown project command: $subcmd. Run 'cco project --help'." ;;
        esac || _cco_rc=$?
        ;;
    pack)
        subcmd="${1:-}"
        if [[ -z "$subcmd" || "$subcmd" == "--help" || "$subcmd" == "-h" ]]; then
            cat <<'EOF'
Usage: cco pack <command> [options]

Commands:
  create <name>          Create a new knowledge pack
  install <url>          Install packs from a remote sharing repo
  update <name>          Update a pack from its remote source
  publish <name> [remote] Publish a pack to a remote sharing repo
  export <name>          Export a pack as .tar.gz archive
  import <archive>       Import a pack from a .tar.gz archive
  internalize <name>     Convert source-referencing pack to self-contained
  show <name>            Show pack details (knowledge, agents, rules)
  remove <name>          Remove a pack
  validate [name]        Validate pack structure (all if no name)

List packs with 'cco list pack' (or 'cco list' for all resources).

Run 'cco pack <command> --help' for command-specific options.
EOF
            exit 0
        fi
        shift
        case "$subcmd" in
            create)   cmd_pack_create "$@" ;;
            install)  cmd_pack_install "$@" ;;
            update)   cmd_pack_update "$@" ;;
            publish)      cmd_pack_publish "$@" ;;
            export)       cmd_pack_export "$@" ;;
            import)       cmd_pack_import "$@" ;;
            internalize)  cmd_pack_internalize "$@" ;;
            list)         die "'cco pack list' was removed — use 'cco list pack' (ADR-0029)." ;;
            show)     cmd_pack_show "$@" ;;
            remove)   cmd_pack_remove "$@" ;;
            validate) cmd_pack_validate "$@" ;;
            *)        die "Unknown pack command: $subcmd. Run 'cco pack --help'." ;;
        esac || _cco_rc=$?
        ;;
    llms)     cmd_llms "$@"     || _cco_rc=$? ;;
    template) cmd_template "$@" || _cco_rc=$? ;;
    chrome)   cmd_chrome "$@"   || _cco_rc=$? ;;
    remote)   cmd_remote "$@"   || _cco_rc=$? ;;
    share|manifest) die "'cco $cmd' has been removed. Sharing repos are discovered by structure (no manifest.yml); use 'cco pack|template publish|install' (ADR-0012/0018)." ;;
    update)   cmd_update "$@"   || _cco_rc=$? ;;
    docs)     cmd_docs "$@"     || _cco_rc=$? ;;
    whoami)   cmd_whoami "$@"   || _cco_rc=$? ;;
    clean)    cmd_clean "$@"    || _cco_rc=$? ;;
    stop)     cmd_stop "$@"     || _cco_rc=$? ;;
    help)     usage "$@" ;;
    *)        die "Unknown command: $cmd. Run 'cco help' for usage." ;;
esac
_cco_completed=true
exit $_cco_rc
