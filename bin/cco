#!/usr/bin/env bash
set -euo pipefail

# ── Constants ────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DEFAULTS_DIR="$REPO_ROOT/defaults"
TEMPLATE_DIR="$DEFAULTS_DIR/_template"
IMAGE_NAME="claude-orchestrator:latest"
LIB_DIR="$REPO_ROOT/lib"

# ── User config directory resolution ─────────────────────────────────
# Primary: CCO_USER_CONFIG_DIR controls the unified user data root.
# Auto-detect: if user-config/ doesn't exist but old global/ does,
# fall back to legacy paths so cco update can run the migration.
USER_CONFIG_DIR="${CCO_USER_CONFIG_DIR:-$REPO_ROOT/user-config}"

if [[ -z "${CCO_USER_CONFIG_DIR:-}" && ! -d "$USER_CONFIG_DIR/global" && -d "$REPO_ROOT/global/.claude" ]]; then
    # Legacy layout — migration not yet run
    GLOBAL_DIR="${CCO_GLOBAL_DIR:-$REPO_ROOT/global}"
    PROJECTS_DIR="${CCO_PROJECTS_DIR:-$REPO_ROOT/projects}"
    PACKS_DIR="${CCO_PACKS_DIR:-$REPO_ROOT/global/packs}"
    TEMPLATES_DIR="${CCO_TEMPLATES_DIR:-$USER_CONFIG_DIR/templates}"
else
    GLOBAL_DIR="${CCO_GLOBAL_DIR:-$USER_CONFIG_DIR/global}"
    PROJECTS_DIR="${CCO_PROJECTS_DIR:-$USER_CONFIG_DIR/projects}"
    PACKS_DIR="${CCO_PACKS_DIR:-$USER_CONFIG_DIR/packs}"
    TEMPLATES_DIR="${CCO_TEMPLATES_DIR:-$USER_CONFIG_DIR/templates}"
fi

# ── Load modules ─────────────────────────────────────────────────────
source "$LIB_DIR/colors.sh"
source "$LIB_DIR/utils.sh"
source "$LIB_DIR/auth.sh"
source "$LIB_DIR/yaml.sh"
source "$LIB_DIR/secrets.sh"
source "$LIB_DIR/workspace.sh"
source "$LIB_DIR/packs.sh"
source "$LIB_DIR/update.sh"
source "$LIB_DIR/cmd-build.sh"
source "$LIB_DIR/cmd-init.sh"
source "$LIB_DIR/cmd-start.sh"
source "$LIB_DIR/cmd-new.sh"
source "$LIB_DIR/cmd-stop.sh"
source "$LIB_DIR/cmd-chrome.sh"
source "$LIB_DIR/cmd-project.sh"
source "$LIB_DIR/cmd-pack.sh"
source "$LIB_DIR/cmd-update.sh"
source "$LIB_DIR/share.sh"

# ── Deprecation warnings ──────────────────────────────────────────────
# Only warn when legacy vars are set WITHOUT CCO_USER_CONFIG_DIR
if [[ -z "${CCO_USER_CONFIG_DIR:-}" ]]; then
    if [[ -n "${CCO_GLOBAL_DIR:-}" ]]; then
        echo "⚠ CCO_GLOBAL_DIR is deprecated. Use CCO_USER_CONFIG_DIR instead." >&2
        echo "  Current: CCO_GLOBAL_DIR=$CCO_GLOBAL_DIR" >&2
        echo "  Suggested: export CCO_USER_CONFIG_DIR=$(dirname "$CCO_GLOBAL_DIR")" >&2
    fi
    if [[ -n "${CCO_PROJECTS_DIR:-}" ]]; then
        echo "⚠ CCO_PROJECTS_DIR is deprecated. Use CCO_USER_CONFIG_DIR instead." >&2
    fi
fi

usage() {
    cat <<'EOF'
Usage: cco <command> [options]

Commands:
  init                   Initialize user config from defaults
  build                  Build/rebuild the Docker image
  start <project>        Start a session for a configured project
  new                    Start a temporary session with specific repos
  project create <n>     Create a new project from template
  project list           List available projects
  project show <n>       Show project details
  project validate <n>   Validate project structure
  pack create <n>        Create a new pack
  pack list              List available packs
  pack show <n>          Show pack details
  pack remove <n>        Remove a pack
  pack validate [n]      Validate pack structure (all if no name)
  chrome [start|stop|status]  Manage Chrome debug session on host
    [--project <name>]        Auto-detect port from project runtime state
    [--port <n>]              Explicit CDP port (default: 9222)
  share refresh          Regenerate share.yml from packs/ and templates/
  share validate         Cross-check share.yml vs disk
  share show             Display share.yml contents
  update                 Update global/project config from defaults
  stop [project]         Stop running session(s)
  help                   Show this help message

Run 'cco <command> --help' for command-specific help.
EOF
}

# ── Main ─────────────────────────────────────────────────────────────

cmd="${1:-}"
[[ -z "$cmd" ]] && { usage; exit 0; }
shift

case "$cmd" in
    init)    cmd_init "$@" ;;
    build)   cmd_build "$@" ;;
    start)   cmd_start "$@" ;;
    new)     cmd_new "$@" ;;
    project)
        subcmd="${1:-}"
        [[ -z "$subcmd" ]] && die "Usage: cco project <create|list|show|validate>"
        shift
        case "$subcmd" in
            create)   cmd_project_create "$@" ;;
            list)     cmd_project_list "$@" ;;
            show)     cmd_project_show "$@" ;;
            validate) cmd_project_validate "$@" ;;
            *)        die "Unknown project command: $subcmd" ;;
        esac
        ;;
    pack)
        subcmd="${1:-}"
        [[ -z "$subcmd" ]] && die "Usage: cco pack <create|list|show|remove|validate>"
        shift
        case "$subcmd" in
            create)   cmd_pack_create "$@" ;;
            list)     cmd_pack_list "$@" ;;
            show)     cmd_pack_show "$@" ;;
            remove)   cmd_pack_remove "$@" ;;
            validate) cmd_pack_validate "$@" ;;
            *)        die "Unknown pack command: $subcmd" ;;
        esac
        ;;
    chrome)  cmd_chrome "$@" ;;
    share)   cmd_share "$@" ;;
    update)  cmd_update "$@" ;;
    stop)    cmd_stop "$@" ;;
    help)    usage ;;
    *)       die "Unknown command: $cmd. Run 'cco help' for usage." ;;
esac
