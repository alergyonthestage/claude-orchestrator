#!/usr/bin/env bash
# bin/test — pure bash test runner for claude-orchestrator
# Usage: bin/test [--file <name>] [--filter <substr>] [--verbose] [--list]
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TESTS_DIR="$REPO_ROOT/tests"
export REPO_ROOT

# Skip Docker build in cco init — integration tests don't need the image
export CCO_SKIP_BUILD=1

# ── Colors ───────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'
    CYAN='\033[0;36m'; RESET='\033[0m'; BOLD='\033[1m'
else
    GREEN=''; RED=''; YELLOW=''; CYAN=''; RESET=''; BOLD=''
fi

# ── State ─────────────────────────────────────────────────────────────
PASS=0; FAIL=0; TOTAL=0
VERBOSE=false
LIST_ONLY=false
FILE_FILTER=""
NAME_FILTER=""

# ── Parse arguments ──────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        --verbose|-v)  VERBOSE=true; shift ;;
        --list)        LIST_ONLY=true; shift ;;
        --file)        FILE_FILTER="$2"; shift 2 ;;
        --filter)      NAME_FILTER="$2"; shift 2 ;;
        --help|-h)
            cat <<'EOF'
Usage: bin/test [OPTIONS]

Options:
  --file <name>    Run only tests in tests/<name>.sh (e.g. test_init)
  --filter <sub>   Run only test functions matching substring
  --verbose, -v    Show output from passing tests
  --list           List all test function names without running
EOF
            exit 0
            ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

# ── Helpers ──────────────────────────────────────────────────────────
_elapsed_ms() {
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "import time; print(int(time.time()*1000))"
    else
        echo 0
    fi
}

_run_test() {
    local fn_name="$1"
    local file_label="$2"
    local start_ms end_ms elapsed

    start_ms=$(_elapsed_ms)

    local output exit_code=0
    # Run each test in a subshell for isolation; capture output
    output=$(( "$fn_name" ) 2>&1) || exit_code=$?

    end_ms=$(_elapsed_ms)
    elapsed=$(( end_ms - start_ms ))

    TOTAL=$(( TOTAL + 1 ))

    if [[ $exit_code -eq 0 ]]; then
        PASS=$(( PASS + 1 ))
        if $VERBOSE; then
            printf "${GREEN}[PASS]${RESET} %-60s ${CYAN}(%sms)${RESET}\n" "$fn_name" "$elapsed"
            if [[ -n "$output" ]]; then
                echo "$output" | sed 's/^/       /'
            fi
        else
            printf "${GREEN}[PASS]${RESET} %-60s ${CYAN}(%sms)${RESET}\n" "$fn_name" "$elapsed"
        fi
    else
        FAIL=$(( FAIL + 1 ))
        printf "${RED}[FAIL]${RESET} %-60s ${CYAN}(%sms)${RESET}\n" "$fn_name" "$elapsed"
        if [[ -n "$output" ]]; then
            echo "$output" | sed "s/^/       ${RED}│${RESET} /"
        fi
    fi
}

# ── Discovery & Execution ─────────────────────────────────────────────
_discover_and_run() {
    local test_file="$1"
    local file_base
    file_base="$(basename "$test_file" .sh)"

    # Apply file filter
    if [[ -n "$FILE_FILTER" && "$file_base" != "$FILE_FILTER" ]]; then
        return 0
    fi

    # Extract function names from file using grep (before sourcing to avoid side-effects)
    local fn_names=()
    while IFS= read -r fn_name; do
        [[ -z "$fn_name" ]] && continue
        # Apply name filter
        if [[ -n "$NAME_FILTER" && "$fn_name" != *"$NAME_FILTER"* ]]; then
            continue
        fi
        fn_names+=("$fn_name")
    done < <(grep -E '^test_[a-zA-Z0-9_]+[[:space:]]*\(\)' "$test_file" | sed 's/[[:space:]]*().*$//')

    if [[ ${#fn_names[@]} -eq 0 ]]; then
        return 0
    fi

    # Source the file (loads helpers + test functions into current shell)
    # shellcheck source=/dev/null
    source "$test_file"

    # Print file header
    if ! $LIST_ONLY; then
        printf "\n${BOLD}${CYAN}── %s ${RESET}\n" "$file_base"
    fi

    for fn_name in "${fn_names[@]}"; do
        if $LIST_ONLY; then
            echo "$fn_name"
        else
            _run_test "$fn_name" "$file_base"
        fi
    done
}

# Source helpers and mocks into parent shell so subshells inherit them
# shellcheck source=tests/helpers.sh
source "$TESTS_DIR/helpers.sh"
# shellcheck source=tests/mocks.sh
source "$TESTS_DIR/mocks.sh"

# Discover and run all test files
for test_file in "$TESTS_DIR"/test_*.sh; do
    [[ -f "$test_file" ]] || continue
    _discover_and_run "$test_file"
done

# ── Summary ───────────────────────────────────────────────────────────
if ! $LIST_ONLY; then
    echo ""
    echo "────────────────────────────────────────────────"
    if [[ $FAIL -eq 0 ]]; then
        printf "${GREEN}${BOLD}Results: %d passed, %d failed, %d total${RESET}\n" "$PASS" "$FAIL" "$TOTAL"
    else
        printf "${RED}${BOLD}Results: %d passed, %d failed, %d total${RESET}\n" "$PASS" "$FAIL" "$TOTAL"
    fi
    echo "────────────────────────────────────────────────"
fi

[[ $FAIL -eq 0 ]]
